{
  "name": "testnew",
  "version": "1.0.0",
  "description": "Testnew starter project powered by SL-Engine",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx tools/dev.ts",
    "build": "tsx tools/build.ts",
    "typecheck": "tsc --noEmit",
    "assets": "tsx tools/assets.ts",
    "doctor": "tsx tools/doctor.ts",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});const dir='generated';if(fs.existsSync(dir)){for(const file of fs.readdirSync(dir)){if(file.endsWith('.json'))fs.rmSync(dir+'/'+file,{force:true});}}\""
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "4.2.110",
    "@fnx/sl-engine": "file:./vendor/sl-engine",
    "@tweenjs/tween.js": "25.0.0",
    "howler": "2.2.4",
    "pixi.js": "8.18.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "esbuild": "0.24.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
