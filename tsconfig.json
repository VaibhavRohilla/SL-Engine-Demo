{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@fnx/sl-engine": ["../../../../src/index.ts"],
      "@core/*": ["../../../../src/core/*"],
      "@runtime/*": ["../../../../src/runtime/*"],
      "@view/*": ["../../../../src/view/*"],
      "@config/*": ["../../../../src/config/*"],
      "@app/*": ["../../../../src/app/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node"],
    "outDir": "dist",
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/**/*", "tools/**/*"],
  "exclude": ["node_modules", "dist", "generated"]
}
